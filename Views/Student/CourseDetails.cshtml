@model uniManage.Models.Course
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Course Details";
    var isEnrolled = (bool)ViewBag.IsEnrolled;
    var totalAssignments = (int)ViewBag.TotalAssignments;
    var submittedAssignments = (int)ViewBag.SubmittedAssignments;
    var pendingAssignments = (int)ViewBag.PendingAssignments;
    var overdueAssignments = (int)ViewBag.OverdueAssignments;
    var submissions = (Dictionary<int, uniManage.Models.AssignmentSubmission>)ViewBag.Submissions;
}

<div class="page-title">@Model.CourseName (@Model.CourseCode)</div>
<div class="page-subtitle">Course information, materials, and assignments</div>

<!-- Assignment Progress Stats (for enrolled students) -->
@if (isEnrolled && totalAssignments > 0)
{
    <div class="stats-grid" style="margin-bottom: 2rem;">
        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <div class="stat-value">@totalAssignments</div>
            <div class="stat-label">Total Assignments</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-value">@submittedAssignments</div>
            <div class="stat-label">Submitted</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon orange">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-value">@pendingAssignments</div>
            <div class="stat-label">Pending</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon red">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-value">@overdueAssignments</div>
            <div class="stat-label">Overdue</div>
        </div>
    </div>
}

<!-- Course Information -->
<div class="stat-card" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="stat-icon blue">
            @Model.CourseCode.Substring(0, Math.Min(3, Model.CourseCode.Length))
        </div>
        <div>
            <h3 style="margin: 0; font-size: 1.25rem; font-weight: 600;">Course Information</h3>
            <p style="margin: 0; color: #64748b;">Overview and details</p>
        </div>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Description</div>
            <div style="font-weight: 500;">@Model.Description</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Credits</div>
            <div style="font-weight: 500;">@Model.Credits</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Lecturer</div>
            <div style="font-weight: 500;">@(Model.Lecturer != null && Model.Lecturer.User != null ? Model.Lecturer.User.FullName : "Not Assigned")</div>
        </div>
    </div>
</div>

<!-- Course Materials -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Course Materials</div>
    </div>
    
    @if (Model.Materials != null && Model.Materials.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Material Details</th>
                    <th>Description</th>
                    <th>Upload Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var material in Model.Materials)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: #10b981;">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="user-details">
                                    <h4>@material.Title</h4>
                                    <p>Course Material</p>
                                </div>
                            </div>
                        </td>
                        <td>@material.Description</td>
                        <td>
                            <div class="user-details">
                                <h4>@material.UploadDate.ToString("MMM dd, yyyy")</h4>
                                <p>@material.UploadDate.ToString("HH:mm")</p>
                            </div>
                        </td>
                        <td>
                            <a href="@material.FilePath" class="btn-manage" style="color: #10b981;" download>Download</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="color: #374151; margin-bottom: 0.5rem;">No Materials Available</h3>
            <p>No materials have been uploaded for this course yet.</p>
        </div>
    }
</div>

<!-- Assignments -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Assignments</div>
    </div>
    
    @if (Model.Assignments != null && Model.Assignments.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Assignment Details</th>
                    <th>Due Date</th>
                    <th>Max Marks</th>
                    <th>Submission Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assignment in Model.Assignments)
                {
                    var daysUntilDue = (assignment.DueDate - DateTime.Now).Days;
                    var isOverdue = assignment.DueDate < DateTime.Now;
                    var isSubmitted = submissions.ContainsKey(assignment.AssignmentId);
                    var submission = isSubmitted ? submissions[assignment.AssignmentId] : null;
                    var isLate = submission != null && submission.IsLateSubmission;
                    var iconColor = isSubmitted ? (isLate ? "#f59e0b" : "#10b981") : isOverdue ? "#ef4444" : daysUntilDue <= 3 ? "#f59e0b" : "#4f46e5";
                    
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: @iconColor;">
                                    <i class="fas @(isSubmitted ? "fa-check" : "fa-tasks")"></i>
                                </div>
                                <div class="user-details">
                                    <h4>@assignment.Title</h4>
                                    <p>@assignment.Description</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@assignment.DueDate.ToString("MMM dd, yyyy")</h4>
                                <p>
                                    @assignment.DueDate.ToString("HH:mm")
                                    @if (isOverdue && !isSubmitted)
                                    {
                                        <span style="color: #ef4444; font-weight: 500;"> (Overdue)</span>
                                    }
                                    else if (daysUntilDue == 0 && !isSubmitted)
                                    {
                                        <span style="color: #f59e0b; font-weight: 500;"> (Due Today)</span>
                                    }
                                    else if (daysUntilDue > 0 && !isSubmitted)
                                    {
                                        <span> (@daysUntilDue days left)</span>
                                    }
                                </p>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge active">@assignment.MaxMarks Points</span>
                        </td>
                        <td>
                            @if (isSubmitted)
                            {
                                <div>
                                    @if (isLate)
                                    {
                                        <span class="status-badge" style="background: #f59e0b; color: white; font-size: 0.75rem;">
                                            <i class="fas fa-clock"></i> Late
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge success" style="font-size: 0.75rem;">
                                            <i class="fas fa-check"></i> On Time
                                        </span>
                                    }
                                    <div style="font-size: 0.75rem; color: #64748b; margin-top: 0.25rem;">@submission.SubmissionDate.ToString("MMM dd, HH:mm")</div>
                                    @if (submission.Grade.HasValue)
                                    {
                                        <div style="font-size: 0.75rem; color: #10b981; margin-top: 0.25rem; font-weight: 500;">Grade: @submission.Grade/@assignment.MaxMarks</div>
                                    }
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(assignment.FilePath))
                            {
                                <a href="@assignment.FilePath" class="btn-manage" style="color: #10b981;" download>Download</a>
                            }
                            else
                            {
                                <span style="color: #64748b;">No attachment</span>
                            }
                        </td>
                        <td>
                            @if (isSubmitted)
                            {
                                <a href="@Url.Action("SubmitAssignment", "Student", new { id = assignment.AssignmentId })" class="btn-manage" style="color: #4f46e5;">View Submission</a>
                            }
                            else
                            {
                                <a href="@Url.Action("SubmitAssignment", "Student", new { id = assignment.AssignmentId })" class="btn-manage" style="color: @iconColor;">
                                    @(isOverdue ? "Submit Late" : "Submit")
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-clipboard-list" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="color: #374151; margin-bottom: 0.5rem;">No Assignments</h3>
            <p>No assignments have been created for this course yet.</p>
        </div>
    }
</div>

<div style="margin-top: 2rem;">
    <a href="@Url.Action("Dashboard", "Student")" style="background: #64748b; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 500;">Back to Dashboard</a>
</div>