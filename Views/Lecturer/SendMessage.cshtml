@model uniManage.Models.Message

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Send Message";
}

<h2>Send Message</h2>

@using (Html.BeginForm("SendMessage", "Lecturer", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    
    <div class="form-group">
        <label>To:</label>
        @Html.DropDownListFor(m => m.ReceiverId, new SelectList(ViewBag.Users, "UserId", "FullName", ViewBag.ReceiverId), "Select Recipient", new { @class = "form-control" })
    </div>
    
    <div class="form-group">
        <label>Subject:</label>
        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control", Value = ViewBag.Subject })
    </div>
    
    <div class="form-group">
        <label>Message:</label>
        @Html.TextAreaFor(m => m.Body, new { @class = "form-control", rows = 5 })
    </div>
    
    <button type="submit" class="btn btn-primary">Send</button>
    <a href="@Url.Action("Messages", "Lecturer")" class="btn btn-secondary">Cancel</a>
}
