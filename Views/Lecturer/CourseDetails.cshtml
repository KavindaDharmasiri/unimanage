@model uniManage.Models.Course
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Course Details";
}

@Html.AntiForgeryToken()

<div class="page-title">@Model.CourseName (@Model.CourseCode)</div>
<div class="page-subtitle">Manage course content, assignments, and students</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
        @TempData["Success"]
    </div>
}

<!-- Course Information -->
<div class="stat-card" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="stat-icon blue">
            @Model.CourseCode.Substring(0, Math.Min(3, Model.CourseCode.Length))
        </div>
        <div>
            <h3 style="margin: 0; font-size: 1.25rem; font-weight: 600;">Course Information</h3>
            <p style="margin: 0; color: #64748b;">Overview and enrollment details</p>
        </div>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Description</div>
            <div style="font-weight: 500;">@Model.Description</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Credits</div>
            <div style="font-weight: 500;">@Model.Credits</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Enrolled Students</div>
            <div style="font-weight: 500;">@Model.Enrollments.Count / @Model.MaxEnrollment</div>
        </div>
    </div>
</div>

<!-- Enrolled Students -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Enrolled Students</div>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
            <span class="status-badge active">@Model.Enrollments.Count students</span>
            @if (Model.Enrollments.Any(e => e.Status == "Active"))
            {
                <button type="button" id="completeAllBtn" style="background: #10b981; color: white; padding: 0.5rem 1rem; border: none; border-radius: 6px; font-weight: 500; cursor: pointer;" onclick="completeCourse(@Model.CourseId)">
                    <i class="fas fa-check-circle"></i> Complete Course
                </button>
            }
        </div>
    </div>
    
    @if (Model.Enrollments.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Student Details</th>
                    <th>Student Number</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enrollment in Model.Enrollments)
                {
                    <tr id="enrollment-@enrollment.EnrollmentId">
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: #10b981;">
                                    @(enrollment.Student != null && enrollment.Student.User != null ? enrollment.Student.User.FullName.Substring(0, 1).ToUpper() : "N")
                                </div>
                                <div class="user-details">
                                    <h4>@(enrollment.Student != null && enrollment.Student.User != null ? enrollment.Student.User.FullName : "N/A")</h4>
                                    <p>Student</p>
                                </div>
                            </div>
                        </td>
                        <td>@(enrollment.Student != null ? enrollment.Student.StudentNumber : "N/A")</td>
                        <td>@(enrollment.Student != null && enrollment.Student.User != null ? enrollment.Student.User.Email : "N/A")</td>
                        <td>
                            <span class="status-badge @(enrollment.Status.ToLower() == "active" ? "active" : enrollment.Status.ToLower() == "completed" ? "success" : "pending")" id="status-@enrollment.EnrollmentId">@enrollment.Status</span>
                        </td>
                        <td>
                            @if (enrollment.Status == "Active")
                            {
                                <div style="display: flex; gap: 0.5rem;">
                                    <button type="button" style="background: #10b981; color: white; padding: 0.25rem 0.5rem; border: none; border-radius: 4px; font-size: 0.75rem; cursor: pointer;" onclick="updateEnrollmentStatus(@enrollment.EnrollmentId, 'Completed')">
                                        <i class="fas fa-check"></i> Complete
                                    </button>
                                    <button type="button" style="background: #ef4444; color: white; padding: 0.25rem 0.5rem; border: none; border-radius: 4px; font-size: 0.75rem; cursor: pointer;" onclick="updateEnrollmentStatus(@enrollment.EnrollmentId, 'Dropped')">
                                        <i class="fas fa-times"></i> Drop
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span style="color: #64748b; font-size: 0.875rem;">@enrollment.Status</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-users" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="color: #374151; margin-bottom: 0.5rem;">No Students Enrolled</h3>
            <p>No students have enrolled in this course yet.</p>
        </div>
    }
</div>

<!-- Assignments -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Assignments</div>
        <a href="@Url.Action("CreateAssignment", "Lecturer", new { courseId = Model.CourseId })" style="background: #4f46e5; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 500;">Create Assignment</a>
    </div>
    
    @if (Model.Assignments.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Assignment Details</th>
                    <th>Due Date</th>
                    <th>Max Marks</th>
                    <th>Submissions</th>
                    <th>Attachment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assignment in Model.Assignments)
                {
                    var daysUntilDue = (assignment.DueDate - DateTime.Now).Days;
                    var isOverdue = assignment.DueDate < DateTime.Now;
                    var iconColor = isOverdue ? "#ef4444" : daysUntilDue <= 3 ? "#f59e0b" : "#4f46e5";
                    
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: @iconColor;">
                                    <i class="fas fa-tasks"></i>
                                </div>
                                <div class="user-details">
                                    <h4>@assignment.Title</h4>
                                    <p>Assignment</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@assignment.DueDate.ToString("MMM dd, yyyy")</h4>
                                <p>@assignment.DueDate.ToString("HH:mm")</p>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge active">@assignment.MaxMarks Points</span>
                        </td>
                        <td>
                            <span class="status-badge pending">@assignment.Submissions.Count Submissions</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(assignment.FilePath))
                            {
                                <a href="@assignment.FilePath" class="btn-manage" style="color: #10b981;" download>Download</a>
                            }
                            else
                            {
                                <span style="color: #64748b;">No attachment</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="@Url.Action("ViewSubmissions", "Lecturer", new { assignmentId = assignment.AssignmentId })" class="btn-manage">View Submissions</a>
                                <button type="button" style="background: #ef4444; color: white; padding: 0.25rem 0.5rem; border: none; border-radius: 4px; font-size: 0.75rem; cursor: pointer;" onclick="confirmDelete('@Url.Action("DeleteAssignment", "Lecturer", new { id = assignment.AssignmentId })', 'assignment')">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-clipboard-list" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="color: #374151; margin-bottom: 0.5rem;">No Assignments</h3>
            <p style="margin-bottom: 1.5rem;">No assignments have been created for this course yet.</p>
            <a href="@Url.Action("CreateAssignment", "Lecturer", new { courseId = Model.CourseId })" style="background: #4f46e5; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 500;">Create First Assignment</a>
        </div>
    }
</div>

<!-- Course Materials -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Course Materials</div>
        <a href="@Url.Action("UploadMaterial", "Lecturer", new { courseId = Model.CourseId })" style="background: #10b981; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 500;">Upload Material</a>
    </div>
    
    @if (Model.Materials != null && Model.Materials.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Material Details</th>
                    <th>Description</th>
                    <th>Upload Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var material in Model.Materials)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: #10b981;">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="user-details">
                                    <h4>@material.Title</h4>
                                    <p>Course Material</p>
                                </div>
                            </div>
                        </td>
                        <td>@material.Description</td>
                        <td>
                            <div class="user-details">
                                <h4>@material.UploadDate.ToString("MMM dd, yyyy")</h4>
                                <p>@material.UploadDate.ToString("HH:mm")</p>
                            </div>
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <a href="@material.FilePath" class="btn-manage" style="color: #10b981;" download>Download</a>
                                <button type="button" style="background: #ef4444; color: white; padding: 0.25rem 0.5rem; border: none; border-radius: 4px; font-size: 0.75rem; cursor: pointer;" onclick="confirmDelete('@Url.Action("DeleteMaterial", "Lecturer", new { id = material.MaterialId })', 'material')">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="color: #374151; margin-bottom: 0.5rem;">No Materials</h3>
            <p style="margin-bottom: 1.5rem;">No materials have been uploaded for this course yet.</p>
            <a href="@Url.Action("UploadMaterial", "Lecturer", new { courseId = Model.CourseId })" style="background: #10b981; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 500;">Upload First Material</a>
        </div>
    }
</div>

<script>
function confirmDelete(url, type) {
    Swal.fire({
        title: 'Are you sure?',
        text: `Do you want to delete this ${type}?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = url;
        }
    });
}

// Get anti-forgery token
function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

// Complete entire course (bulk update)
function completeCourse(courseId) {
    Swal.fire({
        title: 'Complete Course?',
        text: 'This will mark ALL active students as completed. This action cannot be undone.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#10b981',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Yes, complete course!',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            // Show loading
            Swal.fire({
                title: 'Processing...',
                text: 'Updating enrollment statuses',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });
            
            // Create form data
            const formData = new FormData();
            formData.append('courseId', courseId);
            formData.append('status', 'Completed');
            formData.append('__RequestVerificationToken', getAntiForgeryToken());
            
            // Make AJAX call
            fetch('@Url.Action("BulkUpdateEnrollmentStatus", "Lecturer")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Success!',
                        text: data.message,
                        icon: 'success',
                        confirmButtonColor: '#10b981'
                    }).then(() => {
                        location.reload(); // Refresh page to show updated statuses
                    });
                } else {
                    Swal.fire({
                        title: 'Error!',
                        text: data.message,
                        icon: 'error',
                        confirmButtonColor: '#ef4444'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error!',
                    text: 'An error occurred while updating enrollments.',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
            });
        }
    });
}

// Update individual enrollment status
function updateEnrollmentStatus(enrollmentId, status) {
    const actionText = status === 'Completed' ? 'complete' : 'drop';
    const color = status === 'Completed' ? '#10b981' : '#ef4444';
    
    Swal.fire({
        title: `${status} Student?`,
        text: `Are you sure you want to ${actionText} this student?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: color,
        cancelButtonColor: '#64748b',
        confirmButtonText: `Yes, ${actionText}!`,
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            // Create form data
            const formData = new FormData();
            formData.append('enrollmentId', enrollmentId);
            formData.append('status', status);
            formData.append('__RequestVerificationToken', getAntiForgeryToken());
            
            // Make AJAX call
            fetch('@Url.Action("UpdateEnrollmentStatus", "Lecturer")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update the status badge
                    const statusBadge = document.getElementById(`status-${enrollmentId}`);
                    statusBadge.textContent = status;
                    statusBadge.className = `status-badge ${status.toLowerCase() === 'completed' ? 'success' : 'pending'}`;
                    
                    // Update the row to remove action buttons
                    const row = document.getElementById(`enrollment-${enrollmentId}`);
                    const actionsCell = row.querySelector('td:last-child');
                    actionsCell.innerHTML = `<span style="color: #64748b; font-size: 0.875rem;">${status}</span>`;
                    
                    // Show success message
                    Swal.fire({
                        title: 'Success!',
                        text: data.message,
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    
                    // Hide complete course button if no active students left
                    const activeStatuses = document.querySelectorAll('.status-badge.active');
                    if (activeStatuses.length === 0) {
                        const completeBtn = document.getElementById('completeAllBtn');
                        if (completeBtn) completeBtn.style.display = 'none';
                    }
                } else {
                    Swal.fire({
                        title: 'Error!',
                        text: data.message,
                        icon: 'error',
                        confirmButtonColor: '#ef4444'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    title: 'Error!',
                    text: 'An error occurred while updating the enrollment.',
                    icon: 'error',
                    confirmButtonColor: '#ef4444'
                });
            });
        }
    });
}
</script>