@model uniManage.Models.Assignment

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Create Assignment";
}

<h2>Create Assignment</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@Html.ValidationSummary(true, "", new { @class = "text-danger" })

@using (Html.BeginForm("CreateAssignment", "Lecturer", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    
    if (ViewBag.CourseId != null)
    {
        <input type="hidden" name="CourseId" value="@ViewBag.CourseId" />
    }
    else
    {
        <div class="form-group">
            <label>Course</label>
            <select name="CourseId" class="form-control" required>
                <option value="">Select Course</option>
                @foreach (var course in ViewBag.Courses)
                {
                    <option value="@course.CourseId">@course.CourseCode - @course.CourseName</option>
                }
            </select>
        </div>
    }

    <div class="form-group">
        <label>Title</label>
        <input type="text" name="Title" class="form-control" required />
        @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea name="Description" class="form-control" rows="4"></textarea>
    </div>

    <div class="form-group">
        <label>Due Date</label>
        <input type="datetime-local" name="DueDate" class="form-control" required />
        @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>Max Marks</label>
        <input type="number" name="MaxMarks" class="form-control" required />
        @Html.ValidationMessageFor(m => m.MaxMarks, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>Attachment (Optional)</label>
        <input type="file" name="file" class="form-control" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Create</button>
        @if (ViewBag.CourseId != null)
        {
            <a href="@Url.Action("CourseDetails", "Lecturer", new { id = ViewBag.CourseId })" class="btn btn-secondary">Cancel</a>
        }
        else
        {
            <a href="@Url.Action("Dashboard", "Lecturer")" class="btn btn-secondary">Cancel</a>
        }
    </div>
}
