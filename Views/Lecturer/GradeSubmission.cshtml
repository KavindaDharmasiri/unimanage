@model uniManage.Models.AssignmentSubmission
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Grade Submission";
}

<div class="page-title">Grade Submission</div>
<div class="page-subtitle">Review and grade student assignment submission</div>

<!-- Submission Details -->
<div class="stat-card" style="margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="stat-icon orange">
            <i class="fas fa-clipboard-check"></i>
        </div>
        <div>
            <h3 style="margin: 0; font-size: 1.25rem; font-weight: 600;">Submission Details</h3>
            <p style="margin: 0; color: #64748b;">Review student work and provide feedback</p>
        </div>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Student</div>
            <div style="font-weight: 500;">@Model.Student.User.FullName</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Assignment</div>
            <div style="font-weight: 500;">@Model.Assignment.Title</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Submission Date</div>
            <div style="font-weight: 500;">@Model.SubmissionDate.ToString("MMM dd, yyyy HH:mm")</div>
        </div>
        <div>
            <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.25rem;">Max Marks</div>
            <div style="font-weight: 500;">@Model.Assignment.MaxMarks Points</div>
        </div>
    </div>
    
    <div style="padding: 1.5rem; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0;">
        <div style="color: #64748b; font-size: 0.875rem; margin-bottom: 1rem;">Student Submission</div>
        <div style="white-space: pre-wrap; line-height: 1.6; color: #1a202c;">@Model.SubmissionText</div>
    </div>
</div>

<!-- Grading Form -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Grade Assignment</div>
        @if (Model.Grade.HasValue)
        {
            <span class="status-badge active">Currently: @Model.Grade.Value Points</span>
        }
        else
        {
            <span class="status-badge pending">Not Graded</span>
        }
    </div>
    
    <div style="padding: 2rem;">
        @using (Html.BeginForm("GradeSubmission", "Lecturer", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.SubmissionId" />

            <div class="form-group">
                <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: #1a202c;">Grade (out of @Model.Assignment.MaxMarks)</label>
                <input type="number" name="grade" value="@Model.Grade" max="@Model.Assignment.MaxMarks" required style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" placeholder="Enter grade..." />
            </div>

            <div class="form-group">
                <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: #1a202c;">Feedback</label>
                <textarea name="feedback" rows="6" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; resize: vertical;" placeholder="Provide feedback to the student...">@Model.Feedback</textarea>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" style="background: #10b981; color: white; padding: 0.75rem 1.5rem; border: none; border-radius: 8px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fas fa-check"></i>
                    Submit Grade
                </button>
                <a href="@Url.Action("ViewSubmissions", "Lecturer", new { assignmentId = Model.AssignmentId })" style="background: #64748b; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 500; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fas fa-arrow-left"></i>
                    Back to Submissions
                </a>
            </div>
        }
    </div>
</div>