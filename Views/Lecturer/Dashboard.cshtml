@model uniManage.Models.LecturerDashboardViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Lecturer Dashboard";
}

<div class="page-title">Welcome, @Model.Lecturer.User.FullName</div>
<div class="page-subtitle">Department: @Model.Lecturer.Department</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="fas fa-book"></i>
        </div>
        <div class="stat-value">@Model.Courses.Count</div>
        <div class="stat-label">My Courses</div>
        <div class="stat-change neutral">Active courses</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon orange">
            <i class="fas fa-clipboard-check"></i>
        </div>
        <div class="stat-value">@Model.PendingGrading.Count</div>
        <div class="stat-label">Pending Grading</div>
        <div class="stat-change neutral">Awaiting review</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon green">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-value">@Model.Courses.Sum(c => c.Enrollments.Count)</div>
        <div class="stat-label">Total Students</div>
        <div class="stat-change neutral">Enrolled students</div>
    </div>
</div>

<!-- My Courses Section -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">My Courses</div>
        <a href="@Url.Action("MyCourses", "Lecturer")" class="view-all">View All</a>
    </div>
    
    @if (Model.Courses.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Course Details</th>
                    <th>Credits</th>
                    <th>Enrolled Students</th>
                    <th>Assignments</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: #4f46e5;">
                                    @course.CourseCode.Substring(0, Math.Min(3, course.CourseCode.Length))
                                </div>
                                <div class="user-details">
                                    <h4>@course.CourseName</h4>
                                    <p>@course.CourseCode</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge active">@course.Credits Credits</span>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@course.Enrollments.Count / @course.MaxEnrollment</h4>
                                <p>Students enrolled</p>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge pending">@course.Assignments.Count Assignments</span>
                        </td>
                        <td>
                            <a href="@Url.Action("CourseDetails", "Lecturer", new { id = course.CourseId })" class="btn-manage">View Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-chalkboard-teacher" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="margin-bottom: 0.5rem; color: #374151;">No Courses Assigned</h3>
            <p>You are not assigned to any courses yet. Contact administration for course assignments.</p>
        </div>
    }
</div>

<!-- Pending Grading Section -->
<div class="table-container">
    <div class="table-header">
        <div class="table-title">Pending Grading</div>
        <span class="status-badge pending">@Model.PendingGrading.Count submissions</span>
    </div>
    
    @if (Model.PendingGrading.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Assignment</th>
                    <th>Course</th>
                    <th>Submission Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var submission in Model.PendingGrading.Take(10))
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar-table" style="background: #10b981;">
                                    @submission.Student.User.FullName.Substring(0, 1).ToUpper()
                                </div>
                                <div class="user-details">
                                    <h4>@submission.Student.User.FullName</h4>
                                    <p>@submission.Student.StudentNumber</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@submission.Assignment.Title</h4>
                                <p>Assignment</p>
                            </div>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@submission.Assignment.Course.CourseName</h4>
                                <p>@submission.Assignment.Course.CourseCode</p>
                            </div>
                        </td>
                        <td>
                            <div class="user-details">
                                <h4>@submission.SubmissionDate.ToString("MMM dd, yyyy")</h4>
                                <p>@submission.SubmissionDate.ToString("HH:mm")</p>
                            </div>
                        </td>
                        <td>
                            <a href="@Url.Action("GradeSubmission", "Lecturer", new { id = submission.SubmissionId })" class="btn-manage" style="color: #f59e0b;">Grade</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-clipboard-check" style="font-size: 3rem; margin-bottom: 1rem; color: #cbd5e1;"></i>
            <h3 style="margin-bottom: 0.5rem; color: #374151;">No Pending Grading</h3>
            <p>Great! All submissions have been graded.</p>
        </div>
    }
</div>