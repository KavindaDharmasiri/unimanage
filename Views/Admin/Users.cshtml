@model List<uniManage.Models.UserManagementViewModel>
@{
    ViewBag.Title = "User Management";
    ViewBag.CurrentPage = "Users";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<h1 class="page-title">Users</h1>
<p class="page-subtitle">Manage and monitor all university user accounts</p>

<!-- Add User Button -->
<div style="display: flex; justify-content: flex-end; margin-bottom: 1.5rem;">
    <button onclick="openAddUserModal()" style="background: #4f46e5; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
        <i class="fas fa-plus"></i>
        Add New User
    </button>
</div>

<!-- Filters -->
<div class="filters">
    <div class="filter-search">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Search by name, email or ID" onkeyup="filterTable()">
    </div>
    <select class="filter-dropdown" id="roleFilter" onchange="filterTable()">
        <option value="">All Roles</option>
        <option value="Student">Student</option>
        <option value="Lecturer">Lecturer</option>
        <option value="Administrator">Administrator</option>
    </select>
    <select class="filter-dropdown" id="statusFilter" onchange="filterTable()">
        <option value="">All Status</option>
        <option value="Active">Active</option>
        <option value="Inactive">Inactive</option>
    </select>
    <button class="btn-filters">
        <i class="fas fa-filter"></i>
        More Filters
    </button>
</div>

<!-- Users Table -->
<div class="table-container">
    <table class="table" id="usersTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Email Address</th>
                <th>Department</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            @foreach (var user in Model)
            {
                <tr data-user-id="@user.UserId" 
                    data-user-name="@user.FullName" 
                    data-user-email="@user.Email" 
                    data-user-role="@user.Role" 
                    data-user-dept="@user.Department"
                    data-user-identifier="@user.UserIdentifier">
                    <td>
                        <div class="user-info">
                            <div class="user-avatar-table" style="background: @user.AvatarColor;">
                                @user.Initials
                            </div>
                            <div class="user-details">
                                <h4>@user.FullName</h4>
                                <p>ID: @user.UserIdentifier</p>
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (user.Role == "Student")
                        {
                            <span class="role-badge student">Student</span>
                        }
                        else if (user.Role == "Lecturer")
                        {
                            <span class="role-badge lecturer">Lecturer</span>
                        }
                        else if (user.Role == "Administrator")
                        {
                            <span class="role-badge admin">Admin</span>
                        }
                    </td>
                    <td>@user.Email</td>
                    <td>@user.Department</td>
                    <td>
                        <span class="status-badge active">● Active</span>
                    </td>
                    <td>
                        <a href="@Url.Action("ViewUser", "Admin", new { id = user.UserId })" class="btn-view" style="background: #10b981; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.875rem; margin-right: 0.5rem;">View</a>
                        <a href="#" class="btn-manage" onclick="openManageModal(event, this)">Manage</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <!-- Pagination -->
    <div class="pagination-container">
        <div class="pagination-info">
            Showing <span id="startIndex">1</span> to <span id="endIndex">10</span> of <span id="totalCount">@Model.Count</span> users
        </div>
        <div class="pagination" id="paginationControls">
            <a href="#" onclick="changePage('prev'); return false;" id="prevBtn">Previous</a>
            <div id="pageNumbers"></div>
            <a href="#" onclick="changePage('next'); return false;" id="nextBtn">Next</a>
        </div>
    </div>
</div>

<!-- Manage User Modal -->
<div id="manageUserModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 12px; width: 90%; max-width: 500px; padding: 2rem; position: relative; max-height: 90vh; overflow-y: auto;">
        <button onclick="closeManageModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; color: #64748b; cursor: pointer;">&times;</button>
        
        <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: #1a202c;">Manage User</h2>
        
        <form id="manageUserForm">
            <input type="hidden" id="modalUserId">
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Full Name</label>
                <input type="text" id="modalUserName" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Email Address</label>
                <input type="email" id="modalUserEmail" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Role</label>
                <select id="modalUserRole" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
                    <option value="Student">Student</option>
                    <option value="Lecturer">Lecturer</option>
                    <option value="Administrator">Administrator</option>
                </select>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Department</label>
                <select id="modalUserDept" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; background: white;">
                    <option value="">Select Department</option>
                    @foreach (var department in ViewBag.Departments)
                    {
                        <option value="@department.DepartmentName">@department.DepartmentName</option>
                    }
                </select>
                <small style="color: #64748b; font-size: 0.875rem; margin-top: 0.5rem; display: block;">
                    @ViewBag.DepartmentDebug
                </small>
            </div>
            
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">User ID</label>
                <input type="text" id="modalUserIdentifier" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; background: #f8fafc;" readonly>
            </div>
            
            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button type="button" onclick="closeManageModal()" style="padding: 0.75rem 1.5rem; border: 1px solid #e2e8f0; border-radius: 8px; background: white; color: #64748b; font-weight: 500; cursor: pointer;">Cancel</button>
                <button type="button" onclick="deleteUser()" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #ef4444; color: white; font-weight: 500; cursor: pointer;">Delete User</button>
                <button type="submit" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #4f46e5; color: white; font-weight: 500; cursor: pointer;">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Add User Modal -->
<div id="addUserModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 12px; width: 90%; max-width: 500px; padding: 2rem; position: relative; max-height: 90vh; overflow-y: auto; z-index: 10000;">
        <button onclick="closeAddUserModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; color: #64748b; cursor: pointer;">&times;</button>
        
        <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: #1a202c;">Add New User</h2>
        
        <form id="addUserForm">
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Full Name</label>
                <input type="text" id="addUserName" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Email Address</label>
                <input type="email" id="addUserEmail" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Password</label>
                <input type="password" id="addUserPassword" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required minlength="6">
            </div>
            
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Role</label>
                <select id="addUserRole" onchange="toggleRoleFields()" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem;" required>
                    <option value="">Select Role</option>
                    <option value="Student">Student</option>
                    <option value="Lecturer">Lecturer</option>
                    <option value="Administrator">Administrator</option>
                </select>
            </div>
            
            <div id="studentFields" style="display: none; margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Student Number</label>
                <input type="text" id="addStudentNumber" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; background: #f8fafc;" readonly>
                <small style="color: #64748b; font-size: 0.875rem;">Student number will be auto-generated</small>
            </div>
            
            <div id="lecturerFields" style="display: none; margin-bottom: 1rem;">
                <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: #1a202c;">Department</label>
                <select id="addDepartment" style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; background: white;">
                    <option value="">Select Department</option>
                    @foreach (var department in ViewBag.Departments)
                    {
                        <option value="@department.DepartmentName">@department.DepartmentName</option>
                    }
                </select>
                <small style="color: #64748b; font-size: 0.875rem; margin-top: 0.5rem; display: block;">
                    @ViewBag.DepartmentDebug
                </small>
            </div>
            
            <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1.5rem;">
                <button type="button" onclick="closeAddUserModal()" style="padding: 0.75rem 1.5rem; border: 1px solid #e2e8f0; border-radius: 8px; background: white; color: #64748b; font-weight: 500; cursor: pointer;">Cancel</button>
                <button type="submit" style="padding: 0.75rem 1.5rem; border: none; border-radius: 8px; background: #4f46e5; color: white; font-weight: 500; cursor: pointer;">Create User</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let currentPage = 1;
    let rowsPerPage = 10;
    let filteredRows = [];

    function initPagination() {
        const table = document.getElementById('usersTable');
        const rows = Array.from(table.getElementsByTagName('tbody')[0].getElementsByTagName('tr'));
        filteredRows = rows;
        updatePagination();
    }

    function updatePagination() {
        const totalRows = filteredRows.length;
        const totalPages = Math.ceil(totalRows / rowsPerPage);
        const startIndex = (currentPage - 1) * rowsPerPage;
        const endIndex = Math.min(startIndex + rowsPerPage, totalRows);

        // Hide all rows
        filteredRows.forEach(row => row.style.display = 'none');

        // Show only current page rows
        for (let i = startIndex; i < endIndex; i++) {
            if (filteredRows[i]) {
                filteredRows[i].style.display = '';
            }
        }

        // Update pagination info
        document.getElementById('startIndex').textContent = totalRows > 0 ? startIndex + 1 : 0;
        document.getElementById('endIndex').textContent = endIndex;
        document.getElementById('totalCount').textContent = totalRows;

        // Update page numbers
        const pageNumbers = document.getElementById('pageNumbers');
        pageNumbers.innerHTML = '';
        
        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                const pageBtn = document.createElement('span');
                pageBtn.textContent = i;
                pageBtn.className = i === currentPage ? 'current' : '';
                pageBtn.style.cssText = i === currentPage ? 
                    'background: #4f46e5; color: white; border: 1px solid #4f46e5; padding: 0.5rem 0.75rem; border-radius: 6px; font-weight: 500; font-size: 0.875rem; cursor: pointer; margin: 0 0.25rem;' : 
                    'color: #64748b; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; border-radius: 6px; font-weight: 500; font-size: 0.875rem; cursor: pointer; margin: 0 0.25rem;';
                pageBtn.onclick = () => {
                    currentPage = i;
                    updatePagination();
                };
                pageNumbers.appendChild(pageBtn);
            } else if (i === currentPage - 2 || i === currentPage + 2) {
                const dots = document.createElement('span');
                dots.textContent = '...';
                dots.style.cssText = 'padding: 0.5rem; color: #64748b;';
                pageNumbers.appendChild(dots);
            }
        }

        // Update prev/next buttons
        document.getElementById('prevBtn').style.opacity = currentPage === 1 ? '0.5' : '1';
        document.getElementById('prevBtn').style.pointerEvents = currentPage === 1 ? 'none' : 'auto';
        document.getElementById('nextBtn').style.opacity = currentPage === totalPages ? '0.5' : '1';
        document.getElementById('nextBtn').style.pointerEvents = currentPage === totalPages ? 'none' : 'auto';
    }

    function changePage(direction) {
        const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
        if (direction === 'prev' && currentPage > 1) {
            currentPage--;
        } else if (direction === 'next' && currentPage < totalPages) {
            currentPage++;
        }
        updatePagination();
    }

    function filterTable() {
        const searchInput = document.getElementById('searchInput').value.toLowerCase();
        const roleFilter = document.getElementById('roleFilter').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value.toLowerCase();
        const table = document.getElementById('usersTable');
        const rows = Array.from(table.getElementsByTagName('tbody')[0].getElementsByTagName('tr'));

        filteredRows = rows.filter(row => {
            const name = row.cells[0].textContent.toLowerCase();
            const role = row.cells[1].textContent.toLowerCase();
            const email = row.cells[2].textContent.toLowerCase();
            const status = row.cells[4].textContent.toLowerCase();

            const matchesSearch = name.includes(searchInput) || email.includes(searchInput);
            const matchesRole = roleFilter === '' || role === roleFilter || role.includes(roleFilter);
            const matchesStatus = statusFilter === '' || status === statusFilter || (statusFilter === 'active' && status.includes('active')) || (statusFilter === 'inactive' && status.includes('inactive'));

            return matchesSearch && matchesRole && matchesStatus;
        });

        currentPage = 1;
        updatePagination();
    }

    function openManageModal(event, element) {
        event.preventDefault();
        const row = element.closest('tr');
        
        document.getElementById('modalUserId').value = row.dataset.userId;
        document.getElementById('modalUserName').value = row.dataset.userName;
        document.getElementById('modalUserEmail').value = row.dataset.userEmail;
        document.getElementById('modalUserRole').value = row.dataset.userRole;
        document.getElementById('modalUserDept').value = row.dataset.userDept;
        document.getElementById('modalUserIdentifier').value = row.dataset.userIdentifier;
        
        document.getElementById('manageUserModal').style.display = 'flex';
    }

    function closeManageModal() {
        document.getElementById('manageUserModal').style.display = 'none';
    }

    document.getElementById('manageUserForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const userId = document.getElementById('modalUserId').value;
        const fullName = document.getElementById('modalUserName').value;
        const email = document.getElementById('modalUserEmail').value;
        const role = document.getElementById('modalUserRole').value;
        const department = document.getElementById('modalUserDept').value;

        // Close modal first
        closeManageModal();
        
        Swal.fire({
            title: 'Update User',
            text: 'Are you sure you want to update this user?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#4f46e5',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, update',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                // Send AJAX request to update user
                fetch('@Url.Action("UpdateUser", "Admin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        userId: userId,
                        fullName: fullName,
                        email: email,
                        role: role,
                        department: department
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            title: 'Success!',
                            text: data.message,
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#4f46e5'
                        });
                    }
                })
                .catch(error => {
                    Swal.fire({
                        title: 'Error!',
                        text: 'An error occurred while updating the user',
                        icon: 'error',
                        confirmButtonColor: '#4f46e5'
                    });
                });
            }
        });
    });

    function deleteUser() {
        const userId = document.getElementById('modalUserId').value;
        
        // Close modal first
        closeManageModal();
        
        Swal.fire({
            title: 'Delete User',
            text: 'Are you sure you want to delete this user? This action cannot be undone!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, delete',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                // Send AJAX request to delete user
                fetch('@Url.Action("DeleteUser", "Admin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        userId: userId
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            title: 'Deleted!',
                            text: data.message,
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#4f46e5'
                        });
                    }
                })
                .catch(error => {
                    Swal.fire({
                        title: 'Error!',
                        text: 'An error occurred while deleting the user',
                        icon: 'error',
                        confirmButtonColor: '#4f46e5'
                    });
                });
            }
        });
    }

    function openAddUserModal() {
        document.getElementById('addUserForm').reset();
        document.getElementById('studentFields').style.display = 'none';
        document.getElementById('lecturerFields').style.display = 'none';
        document.getElementById('addUserModal').style.display = 'flex';
    }

    function closeAddUserModal() {
        document.getElementById('addUserModal').style.display = 'none';
    }

    function toggleRoleFields() {
        const role = document.getElementById('addUserRole').value;
        document.getElementById('studentFields').style.display = role === 'Student' ? 'block' : 'none';
        document.getElementById('lecturerFields').style.display = role === 'Lecturer' ? 'block' : 'none';
        
        // Auto-generate student number when Student role is selected
        if (role === 'Student') {
            generateStudentNumber();
        }
    }

    function generateStudentNumber() {
        fetch('@Url.Action("GetNextStudentNumber", "Admin")', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('addStudentNumber').value = data.studentNumber;
            } else {
                console.error('Error generating student number:', data.message);
                document.getElementById('addStudentNumber').value = 'E-0001'; // Fallback
            }
        })
        .catch(error => {
            console.error('Error:', error);
            document.getElementById('addStudentNumber').value = 'E-0001'; // Fallback
        });
    }

    document.getElementById('addUserForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const fullName = document.getElementById('addUserName').value;
        const email = document.getElementById('addUserEmail').value;
        const password = document.getElementById('addUserPassword').value;
        const role = document.getElementById('addUserRole').value;
        const department = document.getElementById('addDepartment').value;

        // Close modal first
        closeAddUserModal();

        Swal.fire({
            title: 'Create User',
            text: 'Are you sure you want to create this user?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#4f46e5',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, create',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                // Send AJAX request to create user (studentNumber is auto-generated on backend)
                fetch('@Url.Action("CreateUser", "Admin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        fullName: fullName,
                        email: email,
                        password: password,
                        role: role,
                        studentNumber: '', // Not used - auto-generated on backend
                        department: department
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            title: 'Success!',
                            text: data.message,
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#4f46e5'
                        });
                    }
                })
                .catch(error => {
                    Swal.fire({
                        title: 'Error!',
                        text: 'An error occurred while creating the user',
                        icon: 'error',
                        confirmButtonColor: '#4f46e5'
                    });
                });
            } else {
                // If cancelled, reopen the modal
                openAddUserModal();
                document.getElementById('addUserName').value = fullName;
                document.getElementById('addUserEmail').value = email;
                document.getElementById('addUserPassword').value = password;
                document.getElementById('addUserRole').value = role;
                document.getElementById('addDepartment').value = department;
                toggleRoleFields();
            }
        });
    });

    // Initialize pagination on page load
    window.onload = function() {
        initPagination();
    };
</script>
