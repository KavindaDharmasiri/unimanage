@model uniManage.Models.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard";
    ViewBag.CurrentPage = "Dashboard";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<h1 class="page-title">System Overview</h1>
<p class="page-subtitle">Real-time performance and management metrics for the UniManage platform.</p>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-value">@Model.TotalStudents.ToString("N0")</div>
        <div class="stat-label">Total Students</div>
        <div class="stat-change positive">@((Model.TotalStudents > 0 ? "+" + ((double)Model.TotalStudents / 100 * 12.5).ToString("F1") : "0"))%</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon orange">
            <i class="fas fa-book"></i>
        </div>
        <div class="stat-value">@Model.TotalCourses</div>
        <div class="stat-label">Active Courses</div>
        <div class="stat-change positive">@((Model.TotalCourses > 0 ? "+" + ((double)Model.TotalCourses / 100 * 3.2).ToString("F1") : "0"))%</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon green">
            <i class="fas fa-server"></i>
        </div>
        <div class="stat-value">@Model.SystemUptime%</div>
        <div class="stat-label">System Health</div>
        <div class="stat-change neutral">Stable</div>
    </div>
    
    <div class="stat-card">
        <div class="stat-icon red">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stat-value">@Model.AverageLatency ms</div>
        <div class="stat-label">Avg. Latency</div>
        <div class="stat-change negative">-0.6s</div>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <h3 class="table-title">Recent User Registrations</h3>
        <a href="@Url.Action("Users", "Admin")" class="view-all">View All</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>USER</th>
                <th>ROLE</th>
                <th>DEPARTMENT</th>
                <th>STATUS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.RecentRegistrations.Take(3))
            {
                <tr>
                    <td>
                        <div class="user-info">
                            <div class="user-avatar" style="background-color: @user.AvatarColor; color: white; font-weight: bold;">@user.Initials</div>
                            <div>
                                <div style="font-weight: 500;">@user.FullName</div>
                                <div style="font-size: 0.875rem; color: #64748b;">@user.Email</div>
                            </div>
                        </div>
                    </td>
                    <td>@user.Role</td>
                    <td>@user.Department</td>
                    <td><span class="status-badge @(user.Status.ToLower())">@user.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="table-container">
    <div class="table-header">
        <h3 class="table-title">System Activity Overview</h3>
    </div>
    <div style="padding: 2rem; text-align: center; color: #64748b;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
            <div style="text-align: center;">
                <div style="font-size: 2rem; font-weight: 700; color: #4f46e5;">@Model.TotalEnrollments</div>
                <div style="font-size: 0.875rem; color: #64748b;">Total Enrollments</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 2rem; font-weight: 700; color: #16a34a;">@Model.ActiveEnrollments</div>
                <div style="font-size: 0.875rem; color: #64748b;">Active Enrollments</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 2rem; font-weight: 700; color: #d97706;">@Model.PendingEnrollments</div>
                <div style="font-size: 0.875rem; color: #64748b;">Pending Enrollments</div>
            </div>
            <div style="text-align: center;">
                <div style="font-size: 2rem; font-weight: 700; color: #dc2626;">@Model.TotalLecturers</div>
                <div style="font-size: 0.875rem; color: #64748b;">Total Lecturers</div>
            </div>
        </div>
        <div style="height: 200px; display: flex; align-items: end; justify-content: center; gap: 8px;">
            @{
                var maxValue = Math.Max(Model.TotalStudents, Math.Max(Model.TotalCourses, Math.Max(Model.TotalEnrollments, Model.TotalLecturers)));
                var studentHeight = maxValue > 0 ? (int)((double)Model.TotalStudents / maxValue * 100) : 20;
                var courseHeight = maxValue > 0 ? (int)((double)Model.TotalCourses / maxValue * 100) : 20;
                var enrollmentHeight = maxValue > 0 ? (int)((double)Model.TotalEnrollments / maxValue * 100) : 20;
                var lecturerHeight = maxValue > 0 ? (int)((double)Model.TotalLecturers / maxValue * 100) : 20;
            }
            <div style="width: 40px; height: @studentHeight%; background: #4f46e5; border-radius: 4px;" title="Students: @Model.TotalStudents"></div>
            <div style="width: 40px; height: @courseHeight%; background: #c7d2fe; border-radius: 4px;" title="Courses: @Model.TotalCourses"></div>
            <div style="width: 40px; height: @enrollmentHeight%; background: #4f46e5; border-radius: 4px;" title="Enrollments: @Model.TotalEnrollments"></div>
            <div style="width: 40px; height: @lecturerHeight%; background: #c7d2fe; border-radius: 4px;" title="Lecturers: @Model.TotalLecturers"></div>
        </div>
    </div>
</div>
