@{
    var currentPage = ViewBag.CurrentPage ?? "Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - UniManage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f8fafc;
            color: #1a202c;
        }
        
        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }
        
        /* Sidebar */
        .sidebar {
            width: 260px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            padding: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
        }
        
        .sidebar-top {
            flex: 1;
            padding: 1.5rem 0;
            overflow-y: auto;
        }
        
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0 1.5rem 2rem;
            color: #4f46e5;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.25rem;
        }
        
        .sidebar-brand i {
            background: #4f46e5;
            color: white;
            padding: 0.5rem;
            border-radius: 8px;
            font-size: 1rem;
        }
        
        .sidebar-role {
            color: #64748b;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        
        .sidebar-nav {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .nav-item {
            margin-bottom: 0.25rem;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            color: #64748b;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
            margin: 0 0.75rem;
            border-radius: 8px;
        }
        
        .nav-link:hover {
            background: #f1f5f9;
            color: #4f46e5;
        }
        
        .nav-link.active {
            background: #4f46e5;
            color: white;
        }
        
        .nav-link i {
            width: 20px;
            text-align: center;
            font-size: 1rem;
        }
        
        .sidebar-bottom {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e2e8f0;
        }
        
        .admin-profile {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            background: #f8fafc;
            border-radius: 8px;
        }
        
        .admin-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #4f46e5;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
        }
        
        .admin-info {
            flex: 1;
        }
        
        .admin-name {
            font-weight: 600;
            font-size: 0.875rem;
            color: #1a202c;
        }
        
        .admin-email {
            font-size: 0.75rem;
            color: #64748b;
        }
        
        .admin-logout {
            background: none;
            border: none;
            color: #64748b;
            font-size: 1rem;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 4px;
            transition: all 0.2s;
        }
        
        .admin-logout:hover {
            background: #fee2e2;
            color: #dc2626;
        }
        
        /* SweetAlert2 Custom Styling */
        .swal2-popup {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
            border-radius: 12px !important;
        }
        
        .swal2-title {
            font-weight: 600 !important;
            color: #1a202c !important;
        }
        
        .swal2-html-container {
            color: #64748b !important;
        }
        
        .swal2-confirm {
            background-color: #dc2626 !important;
            border-radius: 8px !important;
            font-weight: 500 !important;
            padding: 0.5rem 1.5rem !important;
        }
        
        .swal2-cancel {
            background-color: #6b7280 !important;
            border-radius: 8px !important;
            font-weight: 500 !important;
            padding: 0.5rem 1.5rem !important;
        }
        
        /* Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            margin-left: 260px;
        }
        
        /* Header */
        .header {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .search-bar {
            flex: 1;
            max-width: 400px;
            position: relative;
        }
        
        .search-bar input {
            width: 100%;
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #f8fafc;
        }
        
        .search-bar i {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }
        
        .header-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .btn-new {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        /* Content Area */
        .content {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }
        
        .page-title {
            font-size: 1.875rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        
        .page-subtitle {
            color: #64748b;
            margin-bottom: 2rem;
        }
        
        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: white;
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            position: relative;
        }
        
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            font-size: 1.25rem;
        }
        
        .stat-icon.blue { background: #dbeafe; color: #4f46e5; }
        .stat-icon.orange { background: #fed7aa; color: #ea580c; }
        .stat-icon.green { background: #dcfce7; color: #16a34a; }
        .stat-icon.red { background: #fee2e2; color: #dc2626; }
        
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 0.875rem;
            margin-bottom: 0.5rem;
        }
        
        .stat-change {
            font-size: 0.875rem;
            font-weight: 500;
        }
        
        .stat-change.positive { color: #16a34a; }
        .stat-change.negative { color: #dc2626; }
        .stat-change.neutral { color: #64748b; }
        
        /* Tables */
        .table-container {
            background: white;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
            margin-bottom: 2rem;
        }
        
        .table-header {
            padding: 1.5rem;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .table-title {
            font-size: 1.125rem;
            font-weight: 600;
        }
        
        .view-all {
            color: #4f46e5;
            text-decoration: none;
            font-weight: 500;
        }
        
        .table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .table th {
            background: #f8fafc;
            padding: 0.75rem 1.5rem;
            text-align: left;
            font-weight: 500;
            color: #64748b;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .table tbody tr:hover {
            background: #f8fafc;
        }
        
        .user-info {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        
        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: #64748b;
        }
        
        .user-avatar-table {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: white;
            font-size: 0.875rem;
        }
        
        .user-details h4 {
            font-weight: 500;
            margin-bottom: 0.25rem;
            font-size: 0.95rem;
        }
        
        .user-details p {
            color: #64748b;
            font-size: 0.875rem;
            margin: 0;
        }
        
        .role-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
        }
        
        .role-badge.student {
            background: #dbeafe;
            color: #1d4ed8;
        }
        
        .role-badge.lecturer {
            background: #fce7f3;
            color: #be185d;
        }
        
        .role-badge.admin {
            background: #f3e8ff;
            color: #7c2d12;
        }
        
        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 500;
        }
        
        .status-badge.active {
            background: #dcfce7;
            color: #16a34a;
        }
        
        .status-badge.pending {
            background: #fef3c7;
            color: #d97706;
        }
        
        .status-badge.inactive {
            background: #f1f5f9;
            color: #64748b;
        }
        
        .btn-manage {
            color: #4f46e5;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.875rem;
        }
        
        .btn-manage:hover {
            color: #4338ca;
        }
        
        /* Filters */
        .filters {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            align-items: center;
        }
        
        .filter-search {
            flex: 1;
            max-width: 300px;
            position: relative;
        }
        
        .filter-search input {
            width: 100%;
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: white;
        }
        
        .filter-search i {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }
        
        .filter-dropdown {
            padding: 0.5rem 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            color: #64748b;
            font-weight: 500;
        }
        
        .btn-filters {
            padding: 0.5rem 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            color: #64748b;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            background: white;
            border-top: 1px solid #e2e8f0;
        }
        
        .pagination-info {
            color: #64748b;
            font-size: 0.875rem;
        }
        
        .pagination {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        
        .pagination a, .pagination span {
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.875rem;
        }
        
        .pagination a {
            color: #64748b;
            border: 1px solid #e2e8f0;
        }
        
        .pagination a:hover {
            background: #f1f5f9;
            color: #4f46e5;
        }
        
        .pagination .current {
            background: #4f46e5;
            color: white;
            border: 1px solid #4f46e5;
        }
        
        /* Right Panel */
        .right-panel {
            width: 300px;
            background: white;
            border-left: 1px solid #e2e8f0;
            padding: 2rem 1.5rem;
        }
        
        .panel-section {
            margin-bottom: 2rem;
        }
        
        .panel-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }
        
        .task-item {
            display: flex;
            gap: 0.75rem;
            padding: 1rem;
            background: #f8fafc;
            border-radius: 8px;
            margin-bottom: 0.75rem;
        }
        
        .task-icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
        }
        
        .task-icon.warning { background: #fef3c7; color: #d97706; }
        .task-icon.danger { background: #fee2e2; color: #dc2626; }
        .task-icon.info { background: #dbeafe; color: #4f46e5; }
        
        .task-content h4 {
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }
        
        .task-content p {
            font-size: 0.75rem;
            color: #64748b;
            margin-bottom: 0.5rem;
        }
        
        .task-action {
            color: #4f46e5;
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: 500;
        }
        
        .activity-item {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }
        
        .activity-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #4f46e5;
            margin-top: 0.5rem;
        }
        
        .activity-content {
            flex: 1;
        }
        
        .activity-time {
            font-size: 0.75rem;
            color: #94a3b8;
            margin-bottom: 0.25rem;
        }
        
        .activity-text {
            font-size: 0.875rem;
            color: #64748b;
        }
        
        @@media (max-width: 1024px) {
            .right-panel {
                display: none;
            }
        }
        
        @@media (max-width: 768px) {
            .sidebar {
                width: 200px;
            }
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-top">
                <a href="#" class="sidebar-brand">
                    <i class="fas fa-graduation-cap"></i>
                    <div>
                        UniManage
                        <div class="sidebar-role">System Administrator</div>
                    </div>
                </a>
                
                <ul class="sidebar-nav">
                    <li class="nav-item">
                        <a href="@Url.Action("Dashboard", "Admin")" class="nav-link @(currentPage == "Dashboard" ? "active" : "")">
                            <i class="fas fa-th-large"></i>
                            Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Users", "Admin")" class="nav-link @(currentPage == "Users" ? "active" : "")">
                            <i class="fas fa-users"></i>
                            User Management
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Courses", "Admin")" class="nav-link @(currentPage == "Courses" ? "active" : "")">
                            <i class="fas fa-book"></i>
                            Course Management
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Departments", "Admin")" class="nav-link @(currentPage == "Departments" ? "active" : "")">
                            <i class="fas fa-building"></i>
                            Departments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Reports", "Admin")" class="nav-link @(currentPage == "Reports" ? "active" : "")">
                            <i class="fas fa-chart-line"></i>
                            Reports
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Messages", "Admin")" class="nav-link @(currentPage == "Messages" ? "active" : "")">
                            <i class="fas fa-envelope"></i>
                            Messages
                        </a>
                    </li>
                </ul>
            </div>
            
            <div class="sidebar-bottom">
                <div class="admin-profile">
                    <div class="admin-avatar">
                        @if (Session["UserName"] != null)
                        {
                            var userName = Session["UserName"].ToString();
                            var names = userName.Split(' ');
                            if (names.Length >= 2)
                            {
                                @(names[0][0].ToString() + names[names.Length - 1][0].ToString())
                            }
                            else
                            {
                                @userName.Substring(0, Math.Min(2, userName.Length)).ToUpper()
                            }
                        }
                        else
                        {
                            @:AD
                        }
                    </div>
                    <div class="admin-info">
                        <div class="admin-name">@(Session["UserName"] ?? "Administrator")</div>
                        <div class="admin-email">@(Session["UserEmail"] ?? "admin@unimanage.edu")</div>
                    </div>
                    <button onclick="confirmLogout(event)" class="admin-logout" title="Logout">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <!-- Header -->
            <div class="header">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search systems, users, or records...">
                </div>
                <div class="header-actions">
                    <i class="fas fa-bell" style="color: #64748b; font-size: 1.25rem;"></i>
                    <i class="fas fa-question-circle" style="color: #64748b; font-size: 1.25rem;"></i>
                    <button class="btn-new">
                        <i class="fas fa-plus"></i>
                        New Action
                    </button>
                </div>
            </div>
            
            <!-- Content -->
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmLogout(event) {
            event.preventDefault();
            Swal.fire({
                title: 'Logout Confirmation',
                text: 'Are you sure you want to logout?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, logout',
                cancelButtonText: 'Cancel',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Logging out...',
                        text: 'Please wait',
                        icon: 'info',
                        allowOutsideClick: false,
                        allowEscapeKey: false,
                        showConfirmButton: false,
                        timer: 1500,
                        timerProgressBar: true
                    }).then(() => {
                        window.location.href = '@Url.Action("Logout", "Account")';
                    });
                }
            });
        }
    </script>
</body>
</html>
