@model uniManage.Models.Course

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Delete Course";
}

<h2>Delete Course</h2>

<div class="alert alert-warning">
    <p>Are you sure you want to delete this course?</p>
</div>

<div class="course-details">
    <p><strong>Course Code:</strong> @Model.CourseCode</p>
    <p><strong>Course Name:</strong> @Model.CourseName</p>
    <p><strong>Credits:</strong> @Model.Credits</p>
</div>

@using (Html.BeginForm("DeleteCourse", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.CourseId" />
    
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="@Url.Action("Courses", "Admin")" class="btn btn-secondary">Cancel</a>
}
