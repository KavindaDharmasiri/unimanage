@model List<uniManage.Models.Lecturer>
@{
    ViewBag.Title = "Lecturers";
}

<h2>All Lecturers</h2>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #333; color: white;">
            <th style="padding: 10px; text-align: left;">Full Name</th>
            <th style="padding: 10px; text-align: left;">Email</th>
            <th style="padding: 10px; text-align: left;">Department</th>
            <th style="padding: 10px; text-align: left;">Registration Date</th>
            <th style="padding: 10px; text-align: left;">Total Courses</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var lecturer in Model)
        {
            <tr style="border-bottom: 1px solid #ddd;">
                <td style="padding: 10px;">@lecturer.User.FullName</td>
                <td style="padding: 10px;">@lecturer.User.Email</td>
                <td style="padding: 10px;">@lecturer.Department</td>
                <td style="padding: 10px;">@lecturer.User.CreatedDate.ToString("yyyy-MM-dd")</td>
                <td style="padding: 10px;">@ViewBag.CourseCounts[lecturer.UserId]</td>
            </tr>
        }
    </tbody>
</table>

<div style="margin-top: 20px;">
    @Html.ActionLink("Back to Dashboard", "Dashboard", null, new { style = "padding: 10px 20px; background-color: #333; color: white; text-decoration: none; border-radius: 3px;" })
</div>