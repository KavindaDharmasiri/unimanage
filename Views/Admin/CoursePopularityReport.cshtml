@model List<uniManage.Models.CourseReportViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Course Popularity Report";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Course Popularity Report</h2>
    <div>
        <a href="@Url.Action("ExportCoursePDF", "Admin")" class="btn btn-danger">
            <i class="fas fa-file-pdf"></i> Export PDF
        </a>
        <a href="@Url.Action("ExportCourseExcel", "Admin")" class="btn btn-success">
            <i class="fas fa-file-excel"></i> Export Excel
        </a>
    </div>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Course Code</th>
            <th>Course Name</th>
            <th>Total Enrollments</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseCode</td>
                <td>@item.CourseName</td>
                <td><span class="badge bg-primary">@item.EnrollmentCount</span></td>
            </tr>
        }
    </tbody>
</table>

<a href="@Url.Action("Reports", "Admin")" class="btn btn-secondary">
    <i class="fas fa-arrow-left"></i> Back to Reports
</a>
