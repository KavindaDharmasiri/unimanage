@model List<uniManage.Models.Course>
@{
    ViewBag.Title = "Course Management";
    ViewBag.CurrentPage = "Courses";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<h1 class="page-title">Courses</h1>
<p class="page-subtitle">Manage and oversee university course offerings across all departments.</p>

<!-- Add Course Button -->
<div style="display: flex; justify-content: flex-end; margin-bottom: 1.5rem;">
    <a href="@Url.Action("CreateCourse", "Admin")" style="background: #4f46e5; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; cursor: pointer; text-decoration: none;">
        <i class="fas fa-plus"></i>
        Add New Course
    </a>
</div>

<!-- Filters -->
<div class="filters">
    <div class="filter-search">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Search courses by name, code or instructor..." onkeyup="filterTable()">
    </div>
    <select class="filter-dropdown" id="departmentFilter" onchange="filterTable()">
        <option value="">All Departments</option>
        <option value="Computer Science">Computer Science</option>
        <option value="Physics">Physics</option>
        <option value="Economics">Economics</option>
        <option value="Chemistry">Chemistry</option>
        <option value="Mathematics">Mathematics</option>
        <option value="Biology">Biology</option>
    </select>
    <select class="filter-dropdown" id="statusFilter" onchange="filterTable()">
        <option value="">Status: All</option>
        <option value="Active">Active</option>
        <option value="Draft">Draft</option>
        <option value="Archived">Archived</option>
    </select>
    <button class="btn-filters">
        <i class="fas fa-filter"></i>
        More Filters
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom: 1.5rem; padding: 1rem; background: #d1fae5; border: 1px solid #a7f3d0; border-radius: 8px; color: #065f46;">
        @TempData["Success"]
    </div>
}

<!-- Courses Table -->
<div class="table-container">
    <table class="table" id="coursesTable">
        <thead>
            <tr>
                <th>COURSE NAME</th>
                <th>CODE</th>
                <th>DEPARTMENT</th>
                <th>INSTRUCTOR</th>
                <th>STATUS</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            @foreach (var course in Model)
            {
                var instructorName = course.Lecturer != null && course.Lecturer.User != null ? course.Lecturer.User.FullName : "Not Assigned";
                var department = !string.IsNullOrEmpty(course.Department) ? course.Department : "General";
                var initials = "NA";
                var avatarColor = "#64748b";
                
                if (course.Lecturer != null && course.Lecturer.User != null && course.Lecturer.User.FullName != null)
                {
                    var names = course.Lecturer.User.FullName.Split(' ');
                    initials = names.Length >= 2 ? 
                        names[0][0].ToString() + names[names.Length - 1][0].ToString() : 
                        course.Lecturer.User.FullName.Length >= 2 ? course.Lecturer.User.FullName.Substring(0, 2).ToUpper() : course.Lecturer.User.FullName.ToUpper();
                    
                    var colors = new[] { "#4f46e5", "#f59e0b", "#ef4444", "#06b6d4", "#10b981", "#8b5cf6", "#f97316", "#ec4899" };
                    avatarColor = colors[course.CourseId % colors.Length];
                }
                
                <tr data-course-name="@course.CourseName" 
                    data-course-code="@course.CourseCode" 
                    data-department="@department"
                    data-instructor="@instructorName"
                    data-status="Active">
                    <td>
                        <div class="course-info">
                            <h4 style="font-weight: 600; color: #1a202c; margin: 0; font-size: 0.95rem;">@course.CourseName</h4>
                            <p style="color: #64748b; margin: 0; font-size: 0.875rem;">Last updated 2 days ago</p>
                        </div>
                    </td>
                    <td style="font-weight: 500; color: #64748b;">@course.CourseCode</td>
                    <td style="color: #64748b;">@department</td>
                    <td>
                        <div class="instructor-info" style="display: flex; align-items: center; gap: 0.75rem;">
                            <div class="instructor-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: @avatarColor; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 0.75rem;">
                                @initials
                            </div>
                            <span style="color: #1a202c; font-weight: 500;">@instructorName</span>
                        </div>
                    </td>
                    <td>
                        <span class="status-badge active" style="background: #d1fae5; color: #065f46; padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">Active</span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="@Url.Action("EditCourse", "Admin", new { id = course.CourseId })" style="color: #64748b; padding: 0.5rem; border-radius: 6px; hover: background: #f1f5f9; text-decoration: none;" title="Edit Course">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="@Url.Action("DeleteCourse", "Admin", new { id = course.CourseId })" style="color: #ef4444; padding: 0.5rem; border-radius: 6px; hover: background: #fef2f2; text-decoration: none;" title="Delete Course" onclick="return confirm('Are you sure you want to delete this course?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <!-- Pagination -->
    <div class="pagination-container">
        <div class="pagination-info">
            Showing <span id="startIndex">1</span> to <span id="endIndex">@Math.Min(10, Model.Count)</span> of <span id="totalCount">@Model.Count</span> courses
        </div>
        <div class="pagination" id="paginationControls">
            <a href="#" onclick="changePage('prev'); return false;" id="prevBtn">Previous</a>
            <div id="pageNumbers"></div>
            <a href="#" onclick="changePage('next'); return false;" id="nextBtn">Next</a>
        </div>
    </div>
</div>

<script>
    let currentPage = 1;
    let rowsPerPage = 10;
    let filteredRows = [];

    function initPagination() {
        const table = document.getElementById('coursesTable');
        const rows = Array.from(table.getElementsByTagName('tbody')[0].getElementsByTagName('tr'));
        filteredRows = rows;
        updatePagination();
    }

    function updatePagination() {
        const totalRows = filteredRows.length;
        const totalPages = Math.ceil(totalRows / rowsPerPage);
        const startIndex = (currentPage - 1) * rowsPerPage;
        const endIndex = Math.min(startIndex + rowsPerPage, totalRows);

        // Hide all rows
        filteredRows.forEach(row => row.style.display = 'none');

        // Show only current page rows
        for (let i = startIndex; i < endIndex; i++) {
            if (filteredRows[i]) {
                filteredRows[i].style.display = '';
            }
        }

        // Update pagination info
        document.getElementById('startIndex').textContent = totalRows > 0 ? startIndex + 1 : 0;
        document.getElementById('endIndex').textContent = endIndex;
        document.getElementById('totalCount').textContent = totalRows;

        // Update page numbers
        const pageNumbers = document.getElementById('pageNumbers');
        pageNumbers.innerHTML = '';
        
        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                const pageBtn = document.createElement('span');
                pageBtn.textContent = i;
                pageBtn.className = i === currentPage ? 'current' : '';
                pageBtn.style.cssText = i === currentPage ? 
                    'background: #4f46e5; color: white; border: 1px solid #4f46e5; padding: 0.5rem 0.75rem; border-radius: 6px; font-weight: 500; font-size: 0.875rem; cursor: pointer; margin: 0 0.25rem;' : 
                    'color: #64748b; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; border-radius: 6px; font-weight: 500; font-size: 0.875rem; cursor: pointer; margin: 0 0.25rem;';
                pageBtn.onclick = () => {
                    currentPage = i;
                    updatePagination();
                };
                pageNumbers.appendChild(pageBtn);
            } else if (i === currentPage - 2 || i === currentPage + 2) {
                const dots = document.createElement('span');
                dots.textContent = '...';
                dots.style.cssText = 'padding: 0.5rem; color: #64748b;';
                pageNumbers.appendChild(dots);
            }
        }

        // Update prev/next buttons
        document.getElementById('prevBtn').style.opacity = currentPage === 1 ? '0.5' : '1';
        document.getElementById('prevBtn').style.pointerEvents = currentPage === 1 ? 'none' : 'auto';
        document.getElementById('nextBtn').style.opacity = currentPage === totalPages ? '0.5' : '1';
        document.getElementById('nextBtn').style.pointerEvents = currentPage === totalPages ? 'none' : 'auto';
    }

    function changePage(direction) {
        const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
        if (direction === 'prev' && currentPage > 1) {
            currentPage--;
        } else if (direction === 'next' && currentPage < totalPages) {
            currentPage++;
        }
        updatePagination();
    }

    function filterTable() {
        const searchInput = document.getElementById('searchInput').value.toLowerCase();
        const departmentFilter = document.getElementById('departmentFilter').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value.toLowerCase();
        const table = document.getElementById('coursesTable');
        const rows = Array.from(table.getElementsByTagName('tbody')[0].getElementsByTagName('tr'));

        filteredRows = rows.filter(row => {
            const courseName = row.dataset.courseName.toLowerCase();
            const courseCode = row.dataset.courseCode.toLowerCase();
            const department = row.dataset.department.toLowerCase();
            const instructor = row.dataset.instructor.toLowerCase();
            const status = row.dataset.status.toLowerCase();

            const matchesSearch = courseName.includes(searchInput) || courseCode.includes(searchInput) || instructor.includes(searchInput);
            const matchesDepartment = departmentFilter === '' || department.includes(departmentFilter);
            const matchesStatus = statusFilter === '' || status.includes(statusFilter);

            return matchesSearch && matchesDepartment && matchesStatus;
        });

        currentPage = 1;
        updatePagination();
    }

    // Initialize pagination on page load
    window.onload = function() {
        initPagination();
    };
</script>
